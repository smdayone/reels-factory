# Copy to .env and fill in your values

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# SSD external drive letter (check in Windows Explorer)
SSD_DRIVE=D

# Base folder on SSD
SSD_BASE_PATH=D:\Products Reels

# Whisper model size: tiny, base, small, medium, large
# Recommendation: "base" for speed, "small" for better accuracy
WHISPER_MODEL=base

# Demucs model: htdemucs (lightest, recommended for CPU)
DEMUCS_MODEL=htdemucs

# Claude model for script generation
CLAUDE_MODEL=claude-sonnet-4-6

# Target video duration in seconds
TARGET_DURATION=30

# Minimum clip duration to keep (seconds)
MIN_CLIP_DURATION=2

# FFmpeg scene detection threshold (0.0-1.0, lower = more cuts detected)
SCENE_THRESHOLD=0.4

# RAM safety threshold in GB — pause processing if below this
RAM_SAFETY_GB=2

# Max seconds used from each clip (long clips are trimmed).
# Lower = more cuts, more dynamic. Raise for slower-paced content.
MAX_CLIP_DURATION=6

# Background music volume (0.0 – 1.0). 0.07 = 7%, barely audible behind voice.
MUSIC_VOLUME=0.03

# ---------------------------------------------------------------------------
# Music
# ---------------------------------------------------------------------------

# Folder with royalty-free music — subfolders by genre/mood are supported
MUSIC_FOLDER=D:\Music for Shorts

# Music source: "local" (reads MUSIC_FOLDER) or "drive" (Google Drive API)
MUSIC_SOURCE=local

# --- Google Drive (only needed if MUSIC_SOURCE=drive) ---
# DRIVE_MUSIC_FOLDER_ID=
# MUSIC_CACHE_DIR=C:\Users\Windows20\Documents\Files\reels-factory\music_cache
