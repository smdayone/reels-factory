# Copy this file to .env and fill in your values.
# The project runs on both Windows and macOS — see the relevant section below.

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Storage paths
#
# Set SSD_BASE_PATH to the root folder where all keyword folders live.
# This is the only variable you must change — everything else is relative to it.
#
# Windows example (NTFS or exFAT SSD on drive D:):
#   SSD_BASE_PATH=D:\Products Reels
#
# macOS example (exFAT SSD mounted at /Volumes/ReelsFactory):
#   SSD_BASE_PATH=/Volumes/ReelsFactory/Products Reels
#
# macOS example (local folder, no external SSD):
#   SSD_BASE_PATH=/Users/yourname/Products Reels
# ---------------------------------------------------------------------------

# Windows — set your drive letter here (used only if SSD_BASE_PATH is not set)
SSD_DRIVE=D

# Root folder for all keyword / product folders
SSD_BASE_PATH=D:\Products Reels

# ---------------------------------------------------------------------------
# Music
# ---------------------------------------------------------------------------

# Folder with royalty-free MP3s — subfolders by genre/mood are supported.
# Windows : MUSIC_FOLDER=D:\Music for Shorts
# macOS   : MUSIC_FOLDER=/Volumes/ReelsFactory/Music for Shorts
MUSIC_FOLDER=D:\Music for Shorts

# Music source: "local" (reads MUSIC_FOLDER) or "drive" (Google Drive API)
MUSIC_SOURCE=local

# --- Google Drive (only needed if MUSIC_SOURCE=drive) ---
# DRIVE_MUSIC_FOLDER_ID=
# MUSIC_CACHE_DIR=

# ---------------------------------------------------------------------------
# Models
# ---------------------------------------------------------------------------

# Whisper model size: tiny | base | small | medium | large
# Recommendation: "base" for speed, "small" for better accuracy
WHISPER_MODEL=base

# Demucs model — htdemucs is lightest on CPU
DEMUCS_MODEL=htdemucs

# Claude model for script generation and Vision
CLAUDE_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Video settings
# ---------------------------------------------------------------------------

# Target video duration in seconds (also used by the script prompt)
TARGET_DURATION=30

# Clips shorter than this (seconds) are discarded at extraction
MIN_CLIP_DURATION=2

# Clips longer than this are trimmed — keeps cuts fast and dynamic
MAX_CLIP_DURATION=6

# FFmpeg scene detection sensitivity (0.0 = detect every cut, 1.0 = none)
SCENE_THRESHOLD=0.4

# Background music volume (0.0 – 1.0). 0.07 = 7%, barely audible behind voice.
MUSIC_VOLUME=0.03

# Apply FFmpeg sharpening pass after export (unsharp + contrast boost)
# Set to false to skip (faster, slightly lower visual quality)
HD_FILTER=true

# ---------------------------------------------------------------------------
# System
# ---------------------------------------------------------------------------

# Pause processing if free RAM drops below this value (GB)
RAM_SAFETY_GB=2
